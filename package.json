{
  "name": "lesson-loom",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "preview:host": "vite preview --host 127.0.0.1 --port 5173",
    "lint": "eslint .",
    "test:e2e": "playwright test --grep-invert capture",
    "test:smoke": "playwright test e2e/smoke.spec.ts e2e/reduced-motion.spec.ts",
    "capture:screenshots": "playwright test e2e/capture-screenshots.spec.ts",
    "verify": "npm run build && npm run lint && npm run test:e2e",
    "verify:submission": "npm run verify && npm run capture:screenshots"
  },
  "dependencies": {
    "gsap": "^3.15.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@playwright/test": "^1.52.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.5"
  }
}
